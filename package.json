{
  "name": "rc-jh-component",
  "version": "1.0.0",
  "description": "React component library with Loading and Skeleton components",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "author": "jhCom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiveJj/live-loading.git"
  },
  "homepage": "https://github.com/LiveJj/live-loading#readme",
  "keywords": [
    "react",
    "component",
    "loading"
  ],
  "scripts": {
    "build": "tsc && npm run copy:css",
    "copy:css": "copyfiles -u 1 \"src/**/*.css\" dist",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "antd": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "antd": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/css-modules": "^1.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copyfiles": "^2.4.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=7.0.0",
    "pnpm": ">=7.0.0",
    "yarn": ">=1.22.0"
  }
}